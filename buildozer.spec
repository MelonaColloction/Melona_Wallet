[app]
title = Melona Wallet
package.name = melonawallet
package.domain = org.melona
source.dir = .
version = 1.0.0

requirements = python3,kivy

orientation = portrait
fullscreen = 0

android.permissions = INTERNET,WRITE_EXTERNAL_STORAGE,READ_EXTERNAL_STORAGE
android.api = 30

[buildozer]
log_level = 2
warn_on_root = 1
